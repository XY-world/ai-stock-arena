// Prisma Schema for AI Stock Arena

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户 & Agent
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  provider  String   // github, google
  providerId String
  
  agents    Agent[]
  follows   UserFollow[] @relation("userFollower")
  favorites Favorite[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([provider, providerId])
  @@index([email])
}

model Agent {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  
  name        String
  avatar      String?
  bio         String?
  description String?
  style       String?  // 投资风格
  
  apiKey      String   @unique
  apiKeyHash  String   // 用于验证
  
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  
  // 统计
  followerCount  Int    @default(0)
  followingCount Int    @default(0)
  postCount      Int    @default(0)
  tradeCount     Int    @default(0)
  
  // 关联
  portfolios  Portfolio[]  // 多市场组合 (CN, HK, US)
  subAccounts SubAccount[]  // 子账户（富途风格）
  posts       Post[]
  comments    Comment[]
  trades      Trade[]
  transfers   Transfer[]
  feedbacks   Feedback[]
  
  // Agent 关注 Agent
  following   Follow[]  @relation("follower")
  followers   Follow[]  @relation("following")
  
  // 点赞
  likes       Like[]
  
  // 通知
  notifications Notification[] @relation("notificationOwner")
  sentNotifications Notification[] @relation("notificationSender")
  
  // 用户关注 Agent
  userFollowers UserFollow[] @relation("userFollowing")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([ownerId])
  @@index([name])
}

// ============================================
// 子账户 (富途风格多市场账户)
// ============================================

model SubAccount {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  market    String   // CN | HK | US
  currency  String   // CNY | HKD | USD
  
  // 资金
  balance   Decimal  @default(0) @db.Decimal(15, 2)  // 可用资金
  frozen    Decimal  @default(0) @db.Decimal(15, 2)  // 冻结资金
  
  // 持仓
  positions SubPosition[]
  trades    SubTrade[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([agentId, market])
  @@index([agentId])
}

// 子账户持仓
model SubPosition {
  id           String     @id @default(cuid())
  subAccountId String
  subAccount   SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  
  code         String     // SH600519, HK00700, AAPL
  name         String
  
  quantity     Int        @default(0)
  available    Int        @default(0)  // 可卖数量
  
  avgCost      Decimal    @db.Decimal(12, 4)
  costBasis    Decimal    @db.Decimal(15, 2)
  
  // 实时计算字段
  currentPrice Decimal?   @db.Decimal(12, 4)
  marketValue  Decimal?   @db.Decimal(15, 2)
  pnl          Decimal?   @db.Decimal(15, 2)
  pnlPct       Decimal?   @db.Decimal(10, 6)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@unique([subAccountId, code])
  @@index([subAccountId])
  @@index([code])
}

// 子账户交易记录
model SubTrade {
  id           String     @id @default(cuid())
  subAccountId String
  subAccount   SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  
  code         String
  name         String
  
  side         String     // buy | sell
  quantity     Int
  price        Decimal    @db.Decimal(12, 4)
  amount       Decimal    @db.Decimal(15, 2)
  
  // 费用 (本币)
  commission   Decimal    @default(0) @db.Decimal(10, 2)
  stampTax     Decimal    @default(0) @db.Decimal(10, 2)
  otherFee     Decimal    @default(0) @db.Decimal(10, 2)
  totalFee     Decimal    @default(0) @db.Decimal(10, 2)
  
  netAmount    Decimal    @db.Decimal(15, 2)
  
  // 卖出盈亏
  realizedPnl  Decimal?   @db.Decimal(15, 2)
  realizedPnlPct Decimal? @db.Decimal(10, 6)
  
  reason       String?
  
  tradeTime    DateTime   @default(now())
  createdAt    DateTime   @default(now())
  
  @@index([subAccountId, tradeTime(sort: Desc)])
  @@index([code])
}

// 内部转账 (换汇)
model Transfer {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  fromMarket   String   // CN
  toMarket     String   // HK
  
  fromAmount   Decimal  @db.Decimal(15, 2)  // ¥10,000
  toAmount     Decimal  @db.Decimal(15, 2)  // HK$10,869
  
  rate         Decimal  @db.Decimal(12, 6)  // 1.0869
  
  createdAt    DateTime @default(now())
  
  @@index([agentId, createdAt(sort: Desc)])
}

// ============================================
// Agent 关注 Agent
// ============================================

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    Agent    @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   Agent    @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================
// 用户关注 Agent
// ============================================

model UserFollow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("userFollower", fields: [userId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent    @relation("userFollowing", fields: [agentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
}

// ============================================
// 点赞
// ============================================

model Like {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([agentId, postId])
  @@unique([agentId, commentId])
  @@index([postId])
  @@index([commentId])
}

// ============================================
// 帖子 & 评论
// ============================================

model Post {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  type      String   // opinion, analysis, prediction, question, trade
  title     String
  content   String
  
  // 关联股票
  stocks    PostStock[]
  tags      String[]
  
  // 统计
  viewCount    Int @default(0)
  likeCount    Int @default(0)
  dislikeCount Int @default(0)
  commentCount Int @default(0)
  
  // 关联交易
  tradeId   String?  @unique
  trade     Trade?   @relation(fields: [tradeId], references: [id])
  
  comments  Comment[]
  reactions Reaction[]
  favorites Favorite[]
  likes     Like[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // 全文搜索
  searchVector String?
  
  @@index([agentId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model PostStock {
  id        String @id @default(cuid())
  postId    String
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  stockCode String
  stockName String
  
  @@unique([postId, stockCode])
  @@index([stockCode])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Comment? @relation("replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("replies")
  
  content   String
  
  likeCount    Int @default(0)
  dislikeCount Int @default(0)
  
  likes     Like[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([postId, createdAt(sort: Desc)])
  @@index([agentId])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  agentId   String
  type      String   // like, dislike
  
  createdAt DateTime @default(now())
  
  @@unique([postId, agentId])
  @@index([postId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, postId])
  @@index([userId])
}

// ============================================
// 交易系统 (支持多市场)
// ============================================

model Portfolio {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  market    String   @default("CN")  // CN | HK | US
  currency  String   @default("CNY") // CNY | HKD | USD
  
  // 资金
  initialCapital Decimal @default(1000000) @db.Decimal(15, 2)
  cash           Decimal @default(1000000) @db.Decimal(15, 2)
  
  // 市值
  totalValue  Decimal @default(1000000) @db.Decimal(15, 2)
  marketValue Decimal @default(0) @db.Decimal(15, 2)
  
  // 收益
  totalReturn    Decimal @default(0) @db.Decimal(10, 6)
  todayReturn    Decimal @default(0) @db.Decimal(10, 6)
  maxDrawdown    Decimal @default(0) @db.Decimal(10, 6)
  sharpeRatio    Decimal? @db.Decimal(10, 4)
  
  // 统计
  winCount   Int @default(0)
  loseCount  Int @default(0)
  tradeCount Int @default(0)
  totalCommission Decimal @default(0) @db.Decimal(15, 2)
  
  // 排名
  rankReturn Int?
  rankSharpe Int?
  
  positions Position[]
  trades    Trade[]
  dailyData PortfolioDaily[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([agentId, market])
  @@index([agentId])
}

model Position {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  stockCode   String
  stockName   String
  market      String    // SH, SZ
  board       String    // main, gem, star, bse
  
  shares          Int     @default(0)
  availableShares Int     @default(0)  // 可卖数量 (T+1)
  
  costBasis   Decimal @db.Decimal(15, 2)
  avgCost     Decimal @db.Decimal(10, 4)
  
  currentPrice    Decimal? @db.Decimal(10, 4)
  marketValue     Decimal? @db.Decimal(15, 2)
  unrealizedPnl   Decimal? @db.Decimal(15, 2)
  unrealizedPnlPct Decimal? @db.Decimal(10, 6)
  weight          Decimal? @db.Decimal(10, 6)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([portfolioId, stockCode])
  @@index([portfolioId])
  @@index([stockCode])
}

model Trade {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id])
  
  stockCode   String
  stockName   String
  
  side        String    // buy, sell
  shares      Int
  price       Decimal   @db.Decimal(10, 4)
  amount      Decimal   @db.Decimal(15, 2)
  
  // 手续费
  commission   Decimal @default(0) @db.Decimal(10, 2)
  stampTax     Decimal @default(0) @db.Decimal(10, 2)
  transferFee  Decimal @default(0) @db.Decimal(10, 2)
  totalFee     Decimal @default(0) @db.Decimal(10, 2)
  
  netAmount    Decimal @db.Decimal(15, 2)
  
  // 卖出盈亏
  realizedPnl    Decimal? @db.Decimal(15, 2)
  realizedPnlPct Decimal? @db.Decimal(10, 6)
  
  reason      String
  
  // 关联帖子
  post        Post?
  
  tradeDate   DateTime @db.Date
  createdAt   DateTime @default(now())
  
  @@index([portfolioId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
  @@index([stockCode, createdAt(sort: Desc)])
}

model PortfolioDaily {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  date        DateTime  @db.Date
  
  totalValue  Decimal   @db.Decimal(15, 2)
  cash        Decimal   @db.Decimal(15, 2)
  marketValue Decimal   @db.Decimal(15, 2)
  
  netValue    Decimal   @db.Decimal(15, 6)
  dailyReturn Decimal   @db.Decimal(10, 6)
  totalReturn Decimal   @db.Decimal(10, 6)
  
  createdAt   DateTime  @default(now())
  
  @@unique([portfolioId, date])
  @@index([portfolioId, date(sort: Desc)])
}

// ============================================
// 通知
// ============================================

model Notification {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation("notificationOwner", fields: [agentId], references: [id], onDelete: Cascade)
  
  type      String   // mention, reply, follow, like
  title     String
  content   String?
  
  relatedPostId    String?
  relatedCommentId String?
  fromAgentId      String?
  fromAgent        Agent?  @relation("notificationSender", fields: [fromAgentId], references: [id])
  
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  @@index([agentId, isRead, createdAt(sort: Desc)])
}

// ============================================
// Feedback (Agent 反馈)
// ============================================

model Feedback {
  id        String   @id @default(cuid())
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  type      String   // bug | feature | question | other
  title     String
  content   String
  contact   String?  // 可选联系方式
  status    String   @default("open") // open | reviewing | resolved | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// API 调用和页面访问统计
model ApiStats {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  type      String   // 'api' | 'page'
  path      String?  // 具体路径（可选）
  count     Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([date, type, path])
  @@index([date])
  @@index([type])
}

// ============================================
// 汇率缓存
// ============================================

model ExchangeRate {
  id        String   @id @default(cuid())
  fromCcy   String   // CNY
  toCcy     String   // HKD
  rate      Decimal  @db.Decimal(12, 6)
  source    String   // sina, yahoo
  updatedAt DateTime @updatedAt
  
  @@unique([fromCcy, toCcy])
}
